# Telegram Bot (optional — leave empty to disable Telegram)
TELEGRAM_BOT_TOKEN=

# YouTube OAuth - paste the entire client_secret.json content as a single line JSON string
# Or place client_secret.json in the project root
# IMPORTANT: Use "Web application" credential type for web OAuth flow
# Add your redirect URI (OAUTH_REDIRECT_URI below) to authorized redirect URIs in Google Cloud Console
YOUTUBE_CLIENT_SECRET_JSON=

# YouTube refresh token (for Telegram bot only — web UI stores tokens in DB)
YOUTUBE_REFRESH_TOKEN=

# OAuth redirect URI — must match what's configured in Google Cloud Console
# Local: http://localhost:8080/oauth/callback
# Render: https://your-app.onrender.com/oauth/callback
# Railway: https://your-app.up.railway.app/oauth/callback
OAUTH_REDIRECT_URI=http://localhost:8080/oauth/callback

# Session secret for signing cookies (change in production!)
SESSION_SECRET=change-me-in-production

# Allowed Telegram user IDs (comma-separated). Leave empty to allow all users.
ALLOWED_USER_IDS=

# Music track filename in assets/ folder
MUSIC_TRACK_FILENAME=music.mp3

# Firebase config (defaults are set in config.py, override here if needed)
# FIREBASE_PROJECT_ID=aces-c8391
# FIREBASE_DB_URL=https://aces-c8391-default-rtdb.firebaseio.com
# FIREBASE_WEB_API_KEY=your-api-key

# Server
PORT=8080
